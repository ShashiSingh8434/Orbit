# Orbit — Environment Variables
# Copy this file to .env (in the project root) and fill in your actual keys.
# The .env file is gitignored and must NEVER be committed.
#
# Future migration: to move AI processing to a backend proxy
# (Firebase Cloud Functions / Cloud Run), replace GEMINI_API_KEY with
# a BACKEND_URL and implement a new AIProvider that hits that endpoint.
# The rest of the app will not require any changes.

GEMINI_API_KEY=your_gemini_api_key_here
